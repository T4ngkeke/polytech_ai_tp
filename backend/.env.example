# Backend environment — copy this file to .env and fill in real values.
# Never commit the real .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/edudb

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── LLM proxy ─────────────────────────────────────────────────────────────────
# Ollama (local):
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama

# Mistral API (cloud, swap when needed):
# LLM_BASE_URL=https://api.mistral.ai/v1
# LLM_API_KEY=your-mistral-api-key
